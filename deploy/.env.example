# ─────────────────────────────────────────────
# NextStopRussia — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Admin panel credentials
# (can also be changed from the admin Security tab at runtime)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# WhatsApp number for lead redirects (international format, no +)
# e.g. 971501234567  for +971 50 123 4567
WHATSAPP_NUMBER=

# Telegram bot notifications for new leads
# Create a bot via @BotFather, then get your Chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
